# ─────────────────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection
# Get these from your Neon dashboard → Connection Details
# https://console.neon.tech/
# ─────────────────────────────────────────────────────────────────────────────

# Used by Python scripts (loader, Streamlit app)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/pharma_analytics?sslmode=require

# Used by dbt (split out because dbt doesn't parse URL-style connection strings cleanly)
NEON_HOST=ep-xxx.us-east-2.aws.neon.tech
NEON_USER=your_user
NEON_PASSWORD=your_password
NEON_DBNAME=pharma_analytics

# ─────────────────────────────────────────────────────────────────────────────
# Groq API key — get from https://console.groq.com/
# Used for the "Explain This Chart" LLM feature in the Streamlit app
# Free tier is generous (Llama 3.3 70B, fast inference)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# Optional: LangSmith tracing (set LANGCHAIN_TRACING_V2=true to enable)
# ─────────────────────────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=physician-pharma-analytics
# LANGCHAIN_TRACING_V2=false
